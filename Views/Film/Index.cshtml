@model X.PagedList.IPagedList<SinemaDunyasi.Models.Film>
@using X.PagedList.Mvc.Core
@using X.PagedList
@using X.PagedList.Web.Common
<div class="d-flex justify-content-between align-items-center mb-3">
<h2>Film Listesi</h2>
<a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Film
Ekle</a>
</div>
<form asp-action="Index" method="get" class="mb-4">
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
<div class="input-group input-group-sm flex-grow-1" style="max-width:500px;">
<input type="text" name="SearchString" class="form-control" placeholder="Film adı
ara..." value="@ViewData["CurrentFilter"]">
<button class="btn btn-primary" type="submit">Ara</button>
</div>
<div class="col-md-8 text-end d-flex justify-content-end gap-2">
<div class="btn-group btn-group-sm shadow-sm">
<a asp-action="Index" asp-route-sortOrder="@ViewData["YilSortParm"]"
asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-outline-dark">
📅 Yıla Göre Sırala @(ViewData["CurrentSort"]?.ToString() == "yil_asc" ? "↑" :
(ViewData["CurrentSort"]?.ToString() == "yil_desc" ? "↓" : ""))
</a>
<a asp-action="Index" asp-route-sortOrder="@ViewData["PuanSortParm"]"
asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-outline-dark">
⭐ Puana Göre Sırala @(ViewData["CurrentSort"]?.ToString() == "puan_asc" ? "↑" :
(ViewData["CurrentSort"]?.ToString() == "puan_desc" ? "↓" : ""))
</a>
</div>
</div>
</div>
</form>
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-6 g-4">
@foreach (var item in Model)
{
<div class="col">
<div class="card h-100 shadow-sm border-0">
<img src="@item.AfisUrl" class="card-img-top" style="height: 240px; object-fit: cover;"
alt="@item.Ad" />
<div class="card-body p-2 d-flex flex-column text-center">
<h6 class="card-title mb-1 text-truncate">@item.Ad</h6>
<p class="card-text small text-muted mb-2">@item.Yonetmen | @item.Tur</p>
<div class="mt-auto d-flex justify-content-between align-items-center mb-2 px-1">
<span class="small fw-bold">@item.Yil</span>
<span class="badge bg-warning text-dark">⭐ @item.Puan</span>
</div>
<div class="d-grid gap-1">
<div class="btn-group btn-group-sm">
<a asp-action="Edit" asp-route-id="@item.Id" class="btn
btn-warning">Düzenle</a>
<a asp-action="Delete" asp-route-id="@item.Id" class="btn
btn-danger">Sil</a>
</div>
</div>
</div>
</div>
</div>
}
</div>
<div class="d-flex justify-content-center mt-4">
@Html.PagedListPager(Model, page => Url.Action("Index", new { page, sortOrder =
ViewData["CurrentSort"], currentFilter = ViewData["CurrentFilter"] }), new
PagedListRenderOptions {
LiElementClasses = new string[] { "page-item" },
PageClasses = new string[] { "page-link" },
LinkToPreviousPageFormat = "Önceki",
LinkToNextPageFormat = "Sonraki",
DisplayLinkToFirstPage = PagedListDisplayMode.Never,
DisplayLinkToLastPage = PagedListDisplayMode.Never,
DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
DisplayLinkToNextPage = PagedListDisplayMode.Always,
Display = PagedListDisplayMode.Always
})
</div>
